// HoopTrack/Auth/BackendSecrets.swift.example
//
// COPY THIS FILE TO BackendSecrets.swift (drop the .example extension).
// BackendSecrets.swift is gitignored so your real values never leak into
// version control.
//
// The anon key is a client-public value — designed to be shipped in the app.
// It still lives in a gitignored file as a matter of hygiene.

import Foundation

enum BackendSecrets {
    /// Supabase project URL, e.g. https://<project>.supabase.co
    static let supabaseURL = URL(string: "https://REPLACE-ME.supabase.co")!

    /// Supabase anon / public key — starts with "eyJ".
    /// Found in Supabase Dashboard → Settings → API.
    static let supabaseAnonKey = "REPLACE_ME_WITH_ANON_KEY"
}
